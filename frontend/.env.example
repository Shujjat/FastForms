# Copy to frontend/.env — Vite reads VITE_* at build/dev time

# Backend API (default http://localhost:8000 if unset). Same value powers Integrations → Swagger/ReDoc links.
# VITE_API_BASE_URL=http://localhost:8000

# Google Sign-In Web client ID (OAuth 2.0 Client ID from Google Cloud Console)
# Must match backend GOOGLE_OAUTH_CLIENT_ID
# VITE_GOOGLE_CLIENT_ID=123456789-xxxxx.apps.googleusercontent.com
