# Copy to backend/.env and adjust. Never commit real secrets.

# Required in production (DEBUG=False): long random string (50+ chars)
DJANGO_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# When DEBUG=False, set comma-separated frontend origins (no spaces after commas is fine)
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# Database: postgres (default) or sqlite for quick tests
DB_ENGINE=postgres
DB_NAME=fastforms
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# JWT (optional overrides)
# JWT_ACCESS_MINUTES=30
# JWT_REFRESH_DAYS=7

# Celery (optional; use eager in tests)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# Email (password reset uses this)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@fastforms.local

# Password reset links in emails point here (frontend origin)
FRONTEND_BASE_URL=http://localhost:5173

# Google Sign-In (same Web client ID as frontend VITE_GOOGLE_CLIENT_ID)
# GOOGLE_OAUTH_CLIENT_ID=123456789-xxxxx.apps.googleusercontent.com

# Local LLM via Ollama (OpenAI-compatible API). Leave LLM_PROVIDER unset to disable AI endpoints.
# Install: https://ollama.com — then: ollama pull <model> (or pick an existing model from `ollama list`)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=auto picks a general chat model from installed tags (prefers qwen/phi/llama over code models).
# Or set an exact tag from `ollama list`, e.g. qwen3:latest or phi3:latest
# OLLAMA_MODEL=auto
# OLLAMA_TIMEOUT=300
# OLLAMA_API_KEY=

# Privacy: set to true only for locked-down debugging — logs AI prompt previews and draft titles (see Docs/SECURITY.md).
# AI_LOG_VERBOSE=false

# Optional: auto-delete responses older than N days (0 = off). Schedule: python manage.py purge_old_responses
# RESPONSE_RETENTION_DAYS=0

# --- Stripe billing (creators: Pro = unlimited owned forms, no fill-page branding) ---
# FREE_TIER_MAX_FORMS=5
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # from Stripe Dashboard → Webhooks → signing secret
# STRIPE_PRICE_PRO_MONTHLY=price_...  # optional legacy: checkout without billing_package_id uses this price
# STRIPE_SUBSCRIPTION_PACKAGE_SLUG=plus  # fallback BillingPackage.slug if a subscription price is not linked to any package row
# Prefer storing each paid plan’s Stripe recurring Price ID on Billing packages (stripe_price_id in admin/API).
# Checkout sends only billing_package_id; the server uses the row’s price — clients never pass raw Stripe price IDs.
# Webhooks map subscription line items to packages by matching that same price id after payment.

# Public API v1 (API keys): throttle per key (default 2000/hour)
# API_KEY_THROTTLE_RATE=2000/hour

# OpenAPI schema + Swagger UI at /api/docs/swagger/ (set False in production if you want docs private/off)
# ENABLE_API_DOCS=True

# Production HTTPS (only when DEBUG=False; see Docs/SECURITY.md)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
